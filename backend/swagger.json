{
  "openapi": "3.0.0",
  "paths": {
    "/auth/login": {
      "post": {
        "description": "Authenticates a user with email and password and returns a JWT access token to be included in subsequent requests as `Authorization: Bearer <token>`.\n\n**Available credentials for the practice environment:**\n- Admin: `admin@example.com` / `admin123`\n- User: `user@example.com` / `user123`",
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication completed successfully. Returns the access token and the user profile.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Invalid email or password."
          }
        },
        "summary": "Authenticate and issue an access token",
        "tags": [
          "Access Management"
        ]
      }
    },
    "/auth/me": {
      "get": {
        "description": "Returns the profile associated with the JWT access token provided in the Authorization header.",
        "operationId": "AuthController_getProfile",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Authenticated user profile returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid JWT token."
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Retrieve the current authenticated user profile",
        "tags": [
          "Access Management"
        ]
      }
    },
    "/cars": {
      "get": {
        "operationId": "CarsController_getAllCars",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "description": "Page number to retrieve (1-indexed)",
            "schema": {
              "minimum": 1,
              "default": 1,
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Maximum number of items to return per page",
            "schema": {
              "minimum": 1,
              "default": 10,
              "example": 10,
              "type": "number"
            }
          },
          {
            "name": "brandId",
            "required": false,
            "in": "query",
            "description": "Filter results to a single brand by exact brand identifier",
            "schema": {
              "example": "brand-1",
              "type": "string"
            }
          },
          {
            "name": "modelId",
            "required": false,
            "in": "query",
            "description": "Filter results to a single model by exact model identifier. Typically combined with brandId.",
            "schema": {
              "example": "model-1",
              "type": "string"
            }
          },
          {
            "name": "minPrice",
            "required": false,
            "in": "query",
            "description": "Return only vehicles whose price is greater than or equal to this value",
            "schema": {
              "minimum": 0,
              "example": 10000,
              "type": "number"
            }
          },
          {
            "name": "maxPrice",
            "required": false,
            "in": "query",
            "description": "Return only vehicles whose price is lower than or equal to this value",
            "schema": {
              "minimum": 0,
              "example": 40000,
              "type": "number"
            }
          },
          {
            "name": "minYear",
            "required": false,
            "in": "query",
            "description": "Return only vehicles manufactured in or after this year",
            "schema": {
              "minimum": 1900,
              "example": 2018,
              "type": "number"
            }
          },
          {
            "name": "maxYear",
            "required": false,
            "in": "query",
            "description": "Return only vehicles manufactured in or before this year",
            "schema": {
              "maximum": 2026,
              "example": 2024,
              "type": "number"
            }
          },
          {
            "name": "available",
            "required": false,
            "in": "query",
            "description": "When true, returns only available vehicles. When false, returns only unavailable ones.",
            "schema": {
              "example": true,
              "type": "boolean"
            }
          },
          {
            "name": "licensePlate",
            "required": false,
            "in": "query",
            "description": "Partial, case-insensitive search on the license plate field",
            "schema": {
              "example": "1234",
              "type": "string"
            }
          },
          {
            "name": "sortBy",
            "required": false,
            "in": "query",
            "description": "Field used to sort the vehicle list",
            "schema": {
              "example": "price",
              "enum": [
                "brandId",
                "modelId",
                "total",
                "price",
                "manufactureYear",
                "registrationDate",
                "mileage",
                "licensePlate",
                "availability"
              ],
              "type": "string"
            }
          },
          {
            "name": "sortOrder",
            "required": false,
            "in": "query",
            "description": "Sort direction applied to sortBy",
            "schema": {
              "default": "asc",
              "example": "asc",
              "enum": [
                "asc",
                "desc"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Vehicle catalog returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/PaginatedResponseDto"
                    },
                    {
                      "properties": {
                        "items": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/CarSummary"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "List vehicles with pagination, filters and sorting",
        "tags": [
          "Vehicles"
        ]
      },
      "post": {
        "operationId": "CarsController_createCar",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCarDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Vehicle created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Car"
                }
              }
            }
          },
          "400": {
            "description": "Invalid vehicle payload"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Create a new vehicle entry (ADMIN only)",
        "tags": [
          "Vehicles"
        ]
      }
    },
