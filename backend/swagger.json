            "minimum": 1
          },
          "manufactureYear": {
            "type": "number",
            "description": "Year the car was manufactured. Must be an integer between 1900 and the current year (2026).\nAlso must be less than or equal to the year in registrationDate.",
            "example": 2020,
            "minimum": 1900,
            "maximum": 2026
          },
          "availability": {
            "type": "boolean",
            "description": "Whether the car is currently available for sale. Defaults to true when not provided.",
