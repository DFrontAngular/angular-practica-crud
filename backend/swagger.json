  "info": {
    "title": "NTT Demo Vehicle Catalog API",
    "description": "Backend API for the NTT Angular practice: authentication, vehicle catalog, brands, models, pagination and role-based access.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Account email address",
            "example": "admin@example.com"
          },
          "password": {
            "type": "string",
            "description": "Account password",
            "example": "admin123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserProfileDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique user identifier",
            "example": "1"
          },
          "email": {
            "type": "string",
            "description": "User email address",
            "example": "admin@example.com"
          },
          "name": {
            "type": "string",
            "description": "Display name associated with the account",
            "example": "Admin User"
          },
          "role": {
            "type": "string",
            "description": "Role assigned to the account. ADMIN can create, update and delete vehicles. USER has read-only access.",
            "enum": [
              "ADMIN",
              "USER"
            ],
            "example": "ADMIN"
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "role"
        ]
      },
      "LoginResponseDto": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "JWT bearer token. Include it in the Authorization header as: Bearer <token>",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "user": {
            "description": "Profile of the authenticated user",
            "allOf": [
              {
                "$ref": "#/components/schemas/UserProfileDto"
              }
            ]
          }
        },
        "required": [
          "access_token",
          "user"
        ]
      },
      "PaginatedMetaDto": {
        "type": "object",
        "properties": {
          "totalItems": {
            "type": "number",
            "description": "Total number of records matching the current query",
            "example": 50
          },
          "itemCount": {
            "type": "number",
            "description": "Number of records returned in the current page",
            "example": 10
          },
          "itemsPerPage": {
            "type": "number",
            "description": "Maximum records per page requested by the client",
            "example": 10
          },
          "totalPages": {
            "type": "number",
            "description": "Total number of pages for the current query and limit",
            "example": 5
          },
          "currentPage": {
            "type": "number",
            "description": "Current page number (1-indexed)",
            "example": 1
          },
          "hasNextPage": {
            "type": "boolean",
            "description": "Indicates whether another page exists after the current one",
            "example": true
          },
          "hasPreviousPage": {
            "type": "boolean",
            "description": "Indicates whether a page exists before the current one",
            "example": false
          }
        },
        "required": [
          "totalItems",
          "itemCount",
          "itemsPerPage",
          "totalPages",
          "currentPage",
          "hasNextPage",
          "hasPreviousPage"
        ]
      },
      "PaginatedResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "description": "Collection of records returned for the current page",
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "meta": {
            "description": "Pagination metadata for the current query",
            "allOf": [
              {
